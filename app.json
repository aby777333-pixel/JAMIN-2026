{
  "expo": {
    "name": "JAMIN Properties",
    "slug": "jamin-mobile",
    "version": "1.0.0",
    "description": "JAMIN Properties — a complete real-estate sales ecosystem: discover properties, calculate EMI & ROI, book visits, and (for partners) build a team, earn commissions, generate branded marketing, and track everything. Signature for Fortune.",
    "primaryColor": "#FD0001",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jamin",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F7F7F5",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "co.jaminproperties.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.jaminproperties.app",
      "adaptiveIcon": {
        "backgroundColor": "#FD0001",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F7F5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-sharing",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "JAMIN uses the camera to capture live, geo-verified property photos for your ads and brochures."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JAMIN tags property photos and site visits with your location for verification."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "JAMIN saves generated ads, brochures and your business card to your photo library.",
          "savePhotosPermission": "JAMIN saves generated ads, brochures and your business card to your photo library."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e878917-ad67-417f-90bd-85e37005f1e2"
      }
    },
    "owner": "abetrex"
  }
}
